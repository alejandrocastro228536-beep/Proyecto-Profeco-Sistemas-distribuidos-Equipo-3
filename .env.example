# Plantilla de variables de entorno.
# Copia este archivo a `.env` y rellena tu contrasena real.
# `.env` esta en .gitignore para que la contrasena NO llegue a Git.
#
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env (Windows cmd)
#
# Docker Compose lee `.env` automaticamente al hacer `docker compose up`.
# Para `mvn quarkus:dev` local, exporta la variable antes:
#   PowerShell:  $env:DB_PASSWORD = "tu_contrasena"
#   bash:        export DB_PASSWORD=tu_contrasena

DB_PASSWORD=cambia_esto_por_tu_contrasena
